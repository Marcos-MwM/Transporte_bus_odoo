<odoo>

    <!-- FORM VIEW HEREDADA -->

    <record id="seq_transporte_ruta" model="ir.sequence">
        <field name="name">Secuencia Bus</field>
        <field name="code">transporte.ruta</field>
        <field name="prefix">BUS</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <record id="view_transporte_cliente_extension_form" model="ir.ui.view">
        <field name="name">transporte.clientes.extension.form</field>
        <field name="model">transporte.publico</field>
        <field name="inherit_id" ref="Transporte_clientes.view_transporte_publico_form"/>

        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <notebook>

                    <!-- PESTAÑA DE RUTA -->
                    <page string="Información de Ruta">
                        <group>

                            <group string="Datos del Viaje">
                                <field name="ruta_id"/>
                                <field name="origen" readonly="1"/>
                                <field name="destino" readonly="1"/>
                                <field name="pasaje" readonly="1"/>
                            </group>

                            <group string="Descuentos y Pago">
                                <field name="total_de_descuento"/>
                                <field name="precio_final" readonly="1"/>
                            </group>

                        </group>
                    </page>

                    <!-- PESTAÑA DE IMAGEN -->
                    <page string="Referencia Visual">
                        <group>
                            <field name="imagen_de_referencia"
                                   widget="image"
                                   class="oe_avatar"/>
                        </group>
                    </page>

                </notebook>

            </xpath>

            <!--vista de pago-->

            <xpath expr="//sheet" position="inside">
                <group string='Información de pago'>
                    <field name="metodo_pago"/>
                    <field name="estado_pago" widget='statusbar'/>
                    <field name="fecha_pago" />
                    <field name="numero_comprobante" />
                    <button 
                    name='action_pagado'
                    string='Pagar'
                    class='btn-success'
                    type='object'
                    invisible="estado_pago == 'pagado'"/>
                    <button 
                    name='action_pendiente'
                    string='Pendiente'
                    class='btn-info'
                    type='object'
                    invisible="estado_pago == 'pendiente'"/>
                    <button 
                    name='action_reembolsado'
                    string='Reembolsado'
                    class='btn-danger'
                    type='object'
                    invisible="estado_pago == 'reembolsado'"/>
                </group>
            </xpath>

        </field>
    </record>


    <!-- LIST VIEW HEREDADA -->
    <record id="view_transporte_cliente_extension_list" model="ir.ui.view">
        <field name="name">transporte.clientes.extension.list</field>
        <field name="model">transporte.publico</field>
        <field name="inherit_id" ref="Transporte_clientes.view_transporte_publico_list"/>

        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="ruta_id"/>
                <field name="origen"/>
                <field name="destino"/>
                <field name="pasaje"/>
                <field name="total_de_descuento"/>
                <field name="precio_final"/>
                <field name='estado_pago' widget='badge'
                decoration-success="estado_pago == 'pagado'"
                decoration-info="estado_pago == 'pendiente'"
                decoration-danger="estado_pago == 'reembolsado'"/>
            </xpath>
        </field>
    </record>

    <record id="filtro_transporte_cliente_extension" model='ir.ui.view'>
        <field name='name'>filtro.transporte.cliente.extension</field>
        <field name='model'>transporte.publico</field>
        <field name='arch' type='xml'>
        <search>
            <filter name='Pagados'
                string='Pagados'
                domain="[('estado_pago', '=', 'pagado')]"/>
            <filter name='Pendiente'
                string='Pendiente'
                domain="[('estado_pago', '=', 'pendiente')]"/>
            <filter name='Reembolso'
                string='Reembolso'
                domain="[('estado_pago', '=', 'reembolsado')]"/>
        </search>
        </field>
    </record>



</odoo>